{
  "name": "xpressintra-employee-app",
  "private": true,
  "version": "1.3.43",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "qa": "node tools/run-qa.cjs",
    "native:sync": "npm run build && cap sync android && cap sync ios",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:apk": "powershell -ExecutionPolicy Bypass -File \"./Build Android APK.ps1\"",
    "android:aab": "npm run android:sync && cd android && gradlew.bat bundleRelease",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.6.5",
    "vite": "^7.0.0"
  }
}
